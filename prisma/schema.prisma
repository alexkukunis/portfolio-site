generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model CaseStudy {
  id            String           @id @default(cuid())
  title         String
  summary       String
  imageUrl      String?
  role          String
  company       String
  year          String
  duration      String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  coverImageUrl String?
  published     Boolean          @default(false)
  publishedAt   DateTime?
  slug          String           @unique
  category      String?
  blocks        CaseStudyBlock[]

  @@index([published, updatedAt])
}

model CaseStudyBlock {
  id          String    @id @default(cuid())
  type        String
  content     Json
  order       Int
  caseStudyId String
  caseStudy   CaseStudy @relation(fields: [caseStudyId], references: [id], onDelete: Cascade)

  @@index([caseStudyId, order])
}

model Skill {
  id          String   @id @default(cuid())
  name        String
  category    String
  proficiency Int      @default(80)
  icon        String?
  createdAt   DateTime @default(now())

  @@index([category])
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read])
}

model Profile {
  id               String   @id @default(cuid())
  name             String
  title            String
  bio              String
  avatarUrl        String?
  email            String?
  linkedin         String?
  github           String?
  twitter          String?
  website          String?
  location         String?
  availableForHire Boolean  @default(true)
  updatedAt        DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([read])
  @@index([createdAt(sort: Desc)])
}
